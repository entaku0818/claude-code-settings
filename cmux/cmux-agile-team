#!/bin/bash
# cmux-agile-team - アジャイルチームを別ワークスペースで開く
#
# Usage:
#   cmux-agile-team          # PDM・デザイナー・エンジニア・マーケター・QAを別ワークスペースで開く
#   cmux-agile-team pdm      # 1人格だけ開く

CMUX="/Applications/cmux.app/Contents/Resources/bin/cmux"

PERSONAS=("pdm" "designer" "engineer" "marketer" "qa")
NAMES=("PDM" "デザイナー" "エンジニア" "マーケター" "QA")
CONTEXTS=(
  "あなたはPDMです。プロダクトの優先順位・ロードマップ・ユーザー価値の観点で、チーム全体のスクラムマスターとして動いてください。"
  "あなたはデザイナーです。UI/UX・ユーザー体験・ビジュアルの観点で考えてください。"
  "あなたはエンジニアです。実装・技術的実現性・コード品質の観点で考えてください。"
  "あなたはマーケターです。集客・ASO・収益化・ユーザー獲得の観点で考えてください。"
  "あなたはQAエンジニアです。品質・クラッシュ・エッジケース・リリース可否の観点で考えてください。"
)

TEAM_CONTEXT="このセッションには以下のメンバーが別ワークスペースにいます：
- PDM: プロダクトの優先順位・ロードマップ・ユーザー価値を担当
- デザイナー: UI/UX・ユーザー体験・ビジュアルを担当
- エンジニア: 実装・技術的実現性・コード品質を担当
- マーケター: 集客・ASO・収益化・ユーザー獲得を担当
- QA: 品質・クラッシュ・エッジケース・リリース可否を担当

## チームの動き方
- 問題が発生したら他のメンバーに相談・協力を求めてください
- 自分だけで解決できない場合は「〇〇の観点でエンジニアに確認が必要」などと明示する
- チームで協力しても解決できないこと・判断できないことはGitHubのissueとして起票してください
  - issueには「何が問題か」「何を試したか」「何が必要か」を明記する
- issueを起票したらユーザーに報告してください

## 作業のやり方
- 具体的な作業（調査・実装・確認など）は自分のワークスペース内で新しいタブ（surface）を開いてエージェントに実行させてください
  - 例: cmux new-surface でタブを作成し、claudeエージェントに作業を指示する
- 作業が完了したらそのタブは閉じてください（cmux close-surface）
- メインのタブは常に会話用として残しておいてください
- 作業タブを開いたら、タブが閉じられるまで定期的に進捗を確認してください（cmux read-screen で監視）
- 完了・エラーを検知したらすぐにユーザーに結果を報告してください"

PROJECT_DIR="$(pwd)"
REPO_NAME=$(basename "$PROJECT_DIR")
WINDOW=$($CMUX current-window)

open_workspace() {
  local NAME="$1"
  local CONTEXT="$2"

  # new-workspace が "OK <UUID>" を返すのでUUIDを取得
  local WS
  WS=$($CMUX new-workspace 2>&1 | awk '{print $2}')

  # 現在のウィンドウに移動
  $CMUX move-workspace-to-window --workspace "$WS" --window "$WINDOW" > /dev/null
  sleep 1

  $CMUX rename-workspace --workspace "$WS" "${REPO_NAME} - ${NAME}" > /dev/null

  # claudeを起動
  $CMUX send --workspace "$WS" "cd \"$PROJECT_DIR\" && claude --dangerously-skip-permissions"
  $CMUX send-key --workspace "$WS" "Enter"

  # claudeが起動するまで待つ（最大15秒）
  for _ in $(seq 1 15); do
    sleep 1
    if $CMUX read-screen --workspace "$WS" 2>/dev/null | grep -q "Claude Code"; then
      break
    fi
  done

  # コンテキストをtmpファイル経由で送信（特殊文字対策）
  local TMPFILE
  TMPFILE=$(mktemp)
  printf '%s\n\n%s' "$CONTEXT" "$TEAM_CONTEXT" > "$TMPFILE"
  $CMUX send --workspace "$WS" "$(cat "$TMPFILE")"
  $CMUX send-key --workspace "$WS" "Enter"
  rm "$TMPFILE"

  # PDMには監視・指示の送り方を別メッセージで送る
  if [ "$NAME" = "PDM" ]; then
    sleep 3
    $CMUX send --workspace "$WS" "/loop 1m cmux list-workspaces でメンバー一覧を確認し、各ワークスペースを cmux read-screen で確認して詰まり・エラーがあれば報告。メンバーへの指示はcmux sendで送りcmux send-keyでEnterを押した後read-screenで認識確認すること。"
    $CMUX send-key --workspace "$WS" "Enter"
  fi
}

stop_team() {
  # PDMワークスペースを探す
  local PDM_WS
  PDM_WS=$($CMUX list-workspaces 2>/dev/null | grep "${REPO_NAME} - PDM" | grep -o '[0-9A-F-]\{36\}')

  if [ -z "$PDM_WS" ]; then
    echo "PDMワークスペースが見つかりません"
    exit 1
  fi

  local LEARNINGS_DIR="/Users/entaku/repository/memo/personas/learnings/${REPO_NAME}"
  local DATE
  DATE=$(date +%Y-%m-%d)
  local OUTFILE="${LEARNINGS_DIR}/${DATE}.md"

  local STOP_PROMPT="チームの作業を終了します。以下の手順で振り返りを実施してください：

1. 各メンバー（デザイナー・エンジニア・マーケター・QA）のワークスペースで以下を実行してください：
   a. \`cmux send\`で「振り返りをまとめてください：今日やったこと・うまくいったこと・課題・次回への知見」と送る
   b. \`cmux send-key Enter\`を押す
   c. 各自の \`/cost\` コマンドを実行させてトークン使用量を取得する
   d. \`cmux read-screen\`で回答を収集する

2. 全員の回答と各自のコンテキスト使用量を集約して、以下のファイルに書き込んでください：
   ${OUTFILE}

   フォーマット：
   # 振り返り - ${REPO_NAME} - ${DATE}
   ## PDM
   ## デザイナー
   ## エンジニア
   ## マーケター
   ## QA
   ## 総括
   ## コンテキスト使用量
   | メンバー | トークン数 | コスト |
   |---|---|---|
   | PDM | - | - |
   | デザイナー | - | - |
   | エンジニア | - | - |
   | マーケター | - | - |
   | QA | - | - |
   | 合計 | - | - |

3. 書き込みが完了したら全メンバーのワークスペースを閉じてください"

  mkdir -p "$LEARNINGS_DIR"

  $CMUX send --workspace "$PDM_WS" "$STOP_PROMPT"
  $CMUX send-key --workspace "$PDM_WS" "Enter"
  echo "PDMに振り返り指示を送りました。完了後にワークスペースが閉じられます。"
}

if [ "${1}" = "stop" ]; then
  stop_team
elif [[ "${1}" =~ ^(pdm|designer|engineer|marketer|qa)$ ]]; then
  for i in "${!PERSONAS[@]}"; do
    if [ "${PERSONAS[$i]}" = "$1" ]; then
      open_workspace "${NAMES[$i]}" "${CONTEXTS[$i]}"
      break
    fi
  done
else
  for i in "${!PERSONAS[@]}"; do
    open_workspace "${NAMES[$i]}" "${CONTEXTS[$i]}"
  done
fi
